{
  "name": "agentic-claude-runner",
  "version": "1.0.0",
  "description": "Agentic Claude Code runner with MCP integration",
  "main": "dist/services/runner/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node -r dotenv/config dist/services/runner/main.js",
    "dev": "ts-node services/runner/main.ts",
    "setup": "npm run build && npm run setup:mcp",
    "setup:mcp": "node scripts/setup-mcp.js",
    "test": "node ./test-runner.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "dotenv": "^17.2.1",
    "express": "^4.18.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0"
  },
  "keywords": [
    "claude",
    "ai",
    "automation",
    "mcp"
  ],
  "author": "Kepa Swanson",
  "license": "MIT"
}
