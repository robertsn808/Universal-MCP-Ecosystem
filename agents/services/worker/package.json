{
  "name": "worker",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "node -r dotenv/config node_modules/ts-node-dev/bin.js --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node -r dotenv/config dist/index.js",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@slack/web-api": "7.1.0",
    "axios": "^1.11.0",
    "cheerio": "1.0.0-rc.12",
    "db": "file:../../packages/db",
    "intent-router": "file:../../packages/intent-router",
    "prom-client": "14.2.0",
    "storage": "file:../../packages/storage",
    "video-adapters": "file:../../packages/video-adapters"
  },
  "devDependencies": {
    "@types/node": "20.12.12",
    "dotenv": "16.4.5",
    "rimraf": "5.0.5",
    "ts-node-dev": "2.0.0",
    "typescript": "5.4.5"
  }
}
