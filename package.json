{
  "name": "upp-mcp-agents",
  "version": "1.0.0",
  "description": "Unified Model Context Protocol agents and servers for the Universal Payment Protocol ecosystem",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "start:dev": "tsx src/index.ts",
    "start:all": "concurrently \"npm run start:aws\" \"npm run start:database\" \"npm run start:payments\" \"npm run start:automation\"",
    "start:aws": "node dist/servers/aws/index.js",
    "start:database": "node dist/servers/database/index.js",
    "start:payments": "node dist/servers/payments/index.js",
    "start:automation": "node dist/servers/automation/index.js",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write src/**/*.{ts,tsx,json}",
    "clean": "rimraf dist",
    "docker:build": "docker build -t upp-mcp-agents .",
    "docker:run": "docker run -p 3000:3000 upp-mcp-agents",
    "prepare": "husky install"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "universal-payment-protocol",
    "upp",
    "agents",
    "automation",
    "payments",
    "aws",
    "database",
    "business"
  ],
  "author": "UPP Development Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.3",
    "@anthropic-ai/sdk": "^0.60.0",
    "@octokit/rest": "^22.0.0",
    "express": "^5.1.0",
    "cors": "^2.8.5",
    "helmet": "^8.1.0",
    "dotenv": "^17.2.1",
    "winston": "^3.17.0",
    "joi": "^17.11.0",
    "axios": "^1.7.9",
    "pg": "^8.16.3",
    "redis": "5.8.1",
    "stripe": "18.4.0",
    "uuid": "^14.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "24.3.0",
    "@types/express": "^5.0.3",
    "@types/cors": "2.8.19",
    "@types/pg": "^8.15.5",
    "@types/uuid": "10.0.0",
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "concurrently": "^8.2.2",
    "rimraf": "^5.0.5",
    "husky": "^9.1.7"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/robertsn808/upp-mcp-agents.git"
  },
  "bugs": {
    "url": "https://github.com/robertsn808/upp-mcp-agents/issues"
  },
  "homepage": "https://github.com/robertsn808/upp-mcp-agents#readme"
}