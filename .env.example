# UPP MCP Agents Configuration

# Core Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
LOG_TO_FILE=true

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/database
REDIS_URL=redis://localhost:6379

# AWS Services
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Payment Processing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# UPP Configuration
UPP_API_URL=http://localhost:9000/api
UPP_API_KEY=your-upp-api-key
UPP_MERCHANT_ID=your-merchant-id

# Ali'i Fish Market
ALII_DB_URL=postgresql://alii_user:alii_password@localhost:5432/alii_fish_market_db
ALII_API_URL=http://localhost:8080/api

# Seller Funnel
SELLER_DB_URL=postgresql://seller_user:seller_password@localhost:5432/seller_db
SELLER_API_URL=http://localhost:8081/api

# External Services
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Twilio (SMS/Voice)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Email Services
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# N8N Automation
N8N_WEBHOOK_URL=http://localhost:5678/webhook
N8N_API_KEY=your-n8n-api-key

# Security
JWT_SECRET=your-super-secure-jwt-secret-at-least-32-characters
ENCRYPTION_KEY=your-32-character-encryption-key
WEBHOOK_SECRET=your-webhook-secret-key

# Monitoring
BETTERSTACK_SOURCE_TOKEN=your-betterstack-token
NEW_RELIC_LICENSE_KEY=your-newrelic-license

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:9000

# Rate Limiting
API_RATE_LIMIT_REQUESTS=1000
API_RATE_LIMIT_WINDOW_MS=900000

# Feature Flags
ENABLE_AWS_INTEGRATION=true
ENABLE_PAYMENT_PROCESSING=true
ENABLE_AUTOMATION=true
ENABLE_ANALYTICS=true

# Development
ENABLE_DEBUG_LOGGING=true
MOCK_EXTERNAL_SERVICES=false